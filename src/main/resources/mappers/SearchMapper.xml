<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--ItemMapper의 위치를 적어줌-->
<mapper namespace="shop.RecommendSystem.repository.mapper.SearchMapper">


    <!-- ════════════════════════════════════
         ResNet-50 + PQ 검색용
         ════════════════════════════════════ -->

    <!-- 메모리 PQ 인덱스 적재용 (@PostConstruct 에서 1회 호출) -->
    <select id="findAllPqCodes" resultType="PqEntry">
        SELECT image_uuid            AS imageUuid,
               pq_code               AS pqCode,
               detected_class        AS detectedClass,
               COALESCE(coarse_id, -1) AS coarseId
        FROM image_info
        WHERE pq_code IS NOT NULL
    </select>

    <!-- Phase 2 재랭킹용 — Top-350 uuid 의 fp16 임베딩 + 상품 정보 JOIN -->
    <select id="findResnet50Phase2Targets" parameterType="map" resultType="SearchResult">
        SELECT
            s.item_id, s.item_title, s.item_price,
            i.image_url, i.image_uuid,
            i.embedding_value AS embeddingValue
        FROM shop_board s
        INNER JOIN image_info i
            ON s.item_id = i.item_id
        WHERE 1=1
        <if test="id != null">
            AND i.item_id != #{id}
        </if>
        <if test="keySet != null and keySet.size() > 0">
            AND i.image_uuid IN
            <foreach collection="keySet" item="item" open="(" close=")" separator=",">
                #{item}
            </foreach>
        </if>
    </select>

</mapper>