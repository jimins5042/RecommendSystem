<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--ItemMapper의 위치를 적어줌-->
<mapper namespace="shop.RecommendSystem.repository.mapper.SearchMapperVggnet">

    <resultMap id="imageResultMap" type="ImageInfo">
        <result column="IMG_FEATURE_VALUE" property="bitarray"/>
    </resultMap>


    <select id="findReduceTarget" resultType="PreFilterDto">
        SELECT image_uuid,
               img_feature_order as featureOrder
        FROM image_info_vggnet
    </select>


    <select id="findPreFilterTargetV2" parameterType="map" resultType="SearchResult">
        SELECT
            s.item_id, s.item_title, s.item_price,
            i.image_url, i.image_uuid, i.img_feature_value as imgFeatureValue
        FROM shop_board s
        INNER JOIN image_info_vggnet i
            ON s.item_id = i.item_id
        WHERE 1=1

        <if test="id == null and keySet == null">
            AND 1=0
        </if>

        <if test="id != null">
            AND i.item_id != #{id}
        </if>

        <if test="keySet != null and keySet.size() > 0">
            AND i.image_uuid IN
            <foreach collection="keySet" item="item" open="(" close=")" separator=",">
                #{item}
            </foreach>
        </if>
    </select>

    <select id="findPreFilterTarget" parameterType="list" resultType="PreFilterDto">
        SELECT image_uuid, img_feature_value
        FROM image_info_vggnet
        WHERE image_uuid IN (
        <foreach collection="list" item="item" separator=", ">
            #{item}
        </foreach>
        )
    </select>

</mapper>